{
  "name": "agentic-research-assistant",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @ara/api run dev",
    "dev:web": "pnpm --filter @ara/web run dev",
    "build": "pnpm -r run build",
    "build:api": "pnpm --filter @ara/api run build",
    "build:web": "pnpm --filter @ara/web run build",
    "format": "pnpm -r run format"
  }
}
